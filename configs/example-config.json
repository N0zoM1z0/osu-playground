{
  "stable_root": "%localappdata%/osu!",
  "audio": {
    "normalize_to_wav": true,
    "normalization_dir": "%TEMP%/osu-lab-audio"
  },
  "replay": {
    "default_profile": "auto_perfect",
    "default_seed": 1,
    "username": "osu-lab"
  },
  "live": {
    "provider": "direct-file/manual",
    "tosu_base_url": "http://127.0.0.1:24050",
    "client_width": 1280,
    "client_height": 960,
    "dry_run": true
  },
  "verification": {
    "external_command": "MapsetVerifier {path}"
  },
  "generation": {
    "prompt": "mixed",
    "target_star": 5.0,
    "target_pp": 220.0,
    "style_index": "D:/osu/style-index.json"
  },
  "ai": {
    "backend": "claude",
    "prompt": "flow aim,jump",
    "seed": 1
  },
  "style": {
    "reference_roots": [
      "D:/osu/Songs/ReferencePack"
    ],
    "preferred_reference_maps": [
      "D:/osu/Songs/ReferencePack/Example/Example [Insane].osu"
    ]
  }
}
